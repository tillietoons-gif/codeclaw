# Ollama connection
OLLAMA_HOST=http://127.0.0.1:11434
CODECLAW_MODEL=qwen2.5-coder:32b

# Agent behavior
CODECLAW_MAX_STEPS=40
CODECLAW_CONTEXT_TOKENS=24000
CODECLAW_TEMPERATURE=0.2

# Safety
# Comma-separated list of command patterns that require confirmation before running.
# Matches if the substring appears anywhere in the command.
CODECLAW_DANGEROUS_PATTERNS=rm -rf,rm -fr,sudo ,mkfs,dd if=,shutdown,reboot,:(){:|:&};:,git push --force,git push -f,DROP TABLE,TRUNCATE,chmod -R 777,curl | bash,wget | bash

# Where project memory lives. CodeClaw auto-loads MEMORY.md and AGENTS.md from here.
CODECLAW_PROJECT_DIR=.
