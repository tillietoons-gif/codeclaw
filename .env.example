# Active provider profile (see /providers in the REPL, or .codeclaw/settings.json)
CODECLAW_PROVIDER=ollama

# LLM backend: ollama | openai (OpenAI-compatible API)
CODECLAW_BACKEND=ollama

# Ollama connection
OLLAMA_HOST=http://127.0.0.1:11434
CODECLAW_MODEL=qwen2.5-coder:32b

# OpenAI-compatible backend (OpenAI, Groq, OpenRouter, vLLM, LM Studio, etc.)
CODECLAW_OPENAI_BASE_URL=http://127.0.0.1:8000/v1
CODECLAW_OPENAI_API_KEY=

# Per-provider API keys (optional; overrides openai_api_key in provider config)
# CODECLAW_PROVIDER_GROQ_API_KEY=
# CODECLAW_PROVIDER_OPENROUTER_API_KEY=

# Agent behavior
CODECLAW_MAX_STEPS=40
CODECLAW_CONTEXT_TOKENS=24000
CODECLAW_TEMPERATURE=0.2

# Where project memory lives. CodeClaw auto-loads MEMORY.md and AGENTS.md from here.
CODECLAW_PROJECT_DIR=.
